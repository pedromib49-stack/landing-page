---
import { getCollection } from 'astro:content';
import LaunchCard from '../components/LaunchCard.astro';

const imoveis = await getCollection('imoveis');
---
<html lang="pt-BR">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Ricardo Mendes — Corretor de Imóveis</title>
  <meta name="description"
    content="Encontre o imóvel certo sem perder tempo. Ricardo Mendes, corretor especialista, atende compradores, vendedores e investidores com curadoria personalizada." />

  <!-- Fonts: Fraunces (display) + DM Sans (body) -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,600;0,9..144,700;1,9..144,300&family=DM+Sans:wght@300;400;500&display=swap"
    rel="stylesheet" />

  <link rel="stylesheet" href="/ricardo-mendes-landing.css" />
</head>

<body>

  <!-- ─── STICKY WA BUTTON (mobile only) ─── -->
  <a class="sticky-wa"
    href="https://wa.me/5511994037626?text=Ol%C3%A1%2C+vim+pelo+site+e+quero+falar+com+o+Ricardo+sobre+im%C3%B3veis"
    target="_blank" rel="noopener">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
      <path
